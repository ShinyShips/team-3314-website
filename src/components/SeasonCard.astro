---
const { year, name, blurb, image, alt, tba, contain = false } = Astro.props;
---
<article class="card">
  <img class={contain ? 'card__img card__img--contain' : 'card__img'} src={image} alt={alt}>
  <div class="card__body">
    <p class="eyebrow">{year} SEASON</p>
    <h3 class="card__title">{name}</h3>
    <p class="card__text">{blurb}</p>
    <a class="mono-link card__link" href={tba} target="_blank" rel="noopener">{year} SEASON STATS &rarr;</a>
  </div>
</article>
