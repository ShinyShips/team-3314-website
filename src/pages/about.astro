---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Marquee from '../components/Marquee.astro';
import universities from '../data/universities.json';
import employers from '../data/employers.json';
import cliftonHigh from '../assets/CliftonHigh.webp';
import teamDinner from '../assets/TeamDinner.jpg';
import kristia from '../assets/Kristia.jpg';

// "Proven outcomes" data — rendered server-side, animated by outcomes.js.
const outcomeRings = [
  { pct: 100, caption: 'of alumni pursue post-secondary plans &mdash; 95% attend college or university, others enter the military.' },
  { pct: 92, caption: 'work in STEM or STEM-adjacent fields after graduation.' },
];
const salaryBaseline = 52624;
const salaryBars = [
  { label: 'Median<br>under-25 NJ', value: 52624, ref: true },
  { label: '1 year<br>on team', value: 70000 },
  { label: '2 years<br>on team', value: 75000 },
  { label: '3 years<br>on team', value: 77500 },
  { label: '4 years<br>on team', value: 84000 },
];
---
<Base title="About — FRC Team 3314, The Mechanical Mustangs" description="Team 3314 exists to prove that where you're from doesn't decide what you can build. Meet the Mechanical Mustangs of Clifton, NJ.">

<Nav active="about" />

<main id="main">

  <!-- PAGE HEADER — photo -->
  <section class="page-header page-header--photo">
    <Image class="page-header__img" src={cliftonHigh} widths={[640, 960, 1440, 1920]} sizes="100vw" loading="eager" fetchpriority="high" alt="Clifton High School with its mustang mural" />
    <div class="page-header__scrim" aria-hidden="true"></div>
    <div class="page-header__content">
      <p class="eyebrow eyebrow--light">ABOUT US</p>
      <h1 class="page-header__title">Ordinary students.<br>Extraordinary outcomes.</h1>
      <p class="page-header__lede" style="color:rgba(255,255,255,.9)">Team 3314 exists to prove that where you're from doesn't decide what you can build.</p>
    </div>
  </section>

  <!-- OUR COMMUNITY -->
  <section class="split reveal">
    <div class="split__copy">
      <p class="eyebrow eyebrow--wide">01 &mdash; OUR COMMUNITY</p>
      <h2 class="split__title">Clifton, New Jersey</h2>
      <p class="split__text">Clifton is one of NJ's most diverse cities &mdash; nearly 40% of residents identify as Hispanic or Latino, over a third are foreign-born, and more than half speak a language other than English at home. For most students here, a future in STEM feels like something that happens to other people, in other places.</p>
      <p class="split__text">We exist to change that.</p>
    </div>
    <div class="split__copy" style="padding:clamp(32px,6vw,96px) clamp(24px,5vw,72px)">
      <div class="stat-grid stat-grid--2col">
        <div class="stat-grid__cell">
          <span class="stat-grid__num" data-count>75%</span>
          <span class="stat-grid__label">MINORITY ENROLLMENT AT CLIFTON HIGH</span>
        </div>
        <div class="stat-grid__cell">
          <span class="stat-grid__num" data-count>61%</span>
          <span class="stat-grid__label">ECONOMICALLY DISADVANTAGED STUDENTS</span>
        </div>
        <div class="stat-grid__cell">
          <span class="stat-grid__num" data-count>14%</span>
          <span class="stat-grid__label">PROFICIENT IN SCIENCE</span>
        </div>
        <div class="stat-grid__cell">
          <span class="stat-grid__num" data-count>50%+</span>
          <span class="stat-grid__label">SPEAK A LANGUAGE OTHER THAN ENGLISH AT HOME</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CULTURE -->
  <section class="split split--white reveal">
    <Image class="split__img split__img--tall" src={teamDinner} widths={[480, 800, 1200, 1600]} sizes="(max-width: 940px) 100vw, 50vw" alt="Team dinner in the shop" />
    <div class="split__copy">
      <p class="eyebrow eyebrow--wide">02 &mdash; OUR CULTURE</p>
      <h2 class="split__title">A family first</h2>
      <p class="split__text">Finances should never be a barrier to passion. Team dues are eliminated entirely through year-round fundraising. We provide nightly family-style meals during build season, cover travel and hotel stays, and make sure every student &mdash; regardless of economic status &mdash; has a seat at the table and a voice in design sessions.</p>
      <div class="checklist">
        <div class="checklist__row"><span class="checklist__arrow">&rarr;</span><span class="checklist__text">$0 dues &mdash; funded through year-round fundraising</span></div>
        <div class="checklist__row"><span class="checklist__arrow">&rarr;</span><span class="checklist__text">Nightly meals during build season, plus weekends</span></div>
        <div class="checklist__row"><span class="checklist__arrow">&rarr;</span><span class="checklist__text">No student turned away &mdash; ever</span></div>
      </div>
    </div>
  </section>

  <!-- PROVEN OUTCOMES -->
  <section class="section reveal" data-outcomes>
    <div class="section-head">
      <h2 class="section-title">03 &mdash; Proven outcomes</h2>
      <span class="kicker">ANNUAL ALUMNI SURVEY</span>
    </div>

    <div class="outcome-rings">
      {outcomeRings.map((r) => (
        <figure class="ring-card">
          <div class="ring">
            <svg viewBox="0 0 120 120" aria-hidden="true">
              <circle class="ring__track" cx="60" cy="60" r="52"></circle>
              <circle class="ring__arc js-ring" cx="60" cy="60" r="52" data-pct={r.pct}></circle>
            </svg>
            <span class="ring__num js-count" data-countup={r.pct} data-suffix="%">{r.pct}%</span>
          </div>
          <figcaption set:html={r.caption}></figcaption>
        </figure>
      ))}
    </div>

    <div class="scholarship">
      <span class="scholarship__num js-count" data-countup="1.5" data-prefix="$" data-suffix="M+" data-decimals="1">$1.5M+</span>
      <p class="scholarship__sub">earned in scholarships &mdash; breaking down financial barriers to opportunity, one Mustang at a time.</p>
    </div>

    <div class="salchart">
      <p class="salchart__title">Median salary &mdash; by years on the team</p>
      <div class="sallegend">
        <span class="sallegend__key sallegend__key--adv"></span> ADVANTAGE OVER THE NJ MEDIAN
        <span class="sallegend__key sallegend__key--base"></span> UP TO THE NJ MEDIAN &mdash; $52,624
      </div>
      <div class="salplot js-salplot" data-baseline={salaryBaseline}>
        <div class="salbase js-salbase" aria-hidden="true"></div>
        {salaryBars.map((b) => (
          <div class="salcol">
            <span class={b.ref ? 'salcol__val salcol__val--base js-count' : 'salcol__val js-count'} data-countup={b.value} data-prefix="$" data-comma="1">${b.value.toLocaleString('en-US')}</span>
            {b.ref ? (
              <div class="salbar salbar--ref js-salbar" data-value={b.value}></div>
            ) : (
              <div class="salbar js-salbar" data-value={b.value}>
                <div class="salbar__adv"></div>
                <div class="salbar__base"></div>
              </div>
            )}
          </div>
        ))}
      </div>
      <div class="sallabels">
        {salaryBars.map((b) => (<span set:html={b.label}></span>))}
      </div>
      <p class="salchart__note">Four years on the team &rarr; <strong>60% more</strong> than the median salary of adults under 25 in NJ. The average alumni starting salary of <strong>$78,116</strong> runs <strong>48% above</strong> that median.</p>
    </div>
  </section>

  <!-- AFTER THE TEAM -->
  <section class="section--white" style="border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:clamp(48px,7vw,88px) 0;background:#fff">
    <div class="section-head" style="margin-bottom:16px;padding:0 var(--pad-x)">
      <h2 class="section-title">Where Mustangs go next</h2>
      <span class="kicker">04 &mdash; AFTER THE TEAM</span>
    </div>
    <p style="margin:0 0 44px;font:400 16.5px/1.6 var(--font-display);color:var(--body);max-width:680px;padding:0 var(--pad-x);text-wrap:pretty">100% of our alumni pursue post-secondary plans. A sample of where recent Mustangs study and work:</p>
    <span class="marquee-label">UNIVERSITIES</span>
    <Marquee wrapClass="marquee--gap" label="Universities our alumni attend" trackClass="marquee__track--unis" wide logos={universities} />
    <span class="marquee-label">EMPLOYERS</span>
    <Marquee label="Employers of our alumni" trackClass="marquee__track--employers" wide logos={employers} />
  </section>

  <!-- IN THEIR WORDS -->
  <section class="section reveal">
    <div class="section-head">
      <h2 class="section-title">In their words</h2>
      <span class="kicker">05 &mdash; STUDENT &amp; MENTOR INTERVIEWS</span>
    </div>
    <div class="words__grid">
      <iframe
        class="video-embed"
        src="https://www.youtube-nocookie.com/embed/ioiwidreJyQ"
        title="Mechanical Mustangs — student and mentor interviews"
        loading="lazy"
        allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen></iframe>
      <blockquote class="words__quote">
        <p class="quote-band__text">&ldquo;I've learned so many skills and met so many people that will help me build a future that I'm proud of. Ultimately, robotics for me means a brighter future.&rdquo;</p>
        <footer class="quote-band__attr">
          <span class="quote-band__name">LAMARR OLIVE</span>
          <span class="quote-band__role">SOFTWARE LEAD, CLASS OF 2025 &middot; NOW AT HARVEY MUDD COLLEGE</span>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- LEADERSHIP PIPELINE -->
  <section class="band band--split band--split-flush reveal">
    <div class="band__copy band__copy--pad">
      <p class="eyebrow eyebrow--band">06 &mdash; THE PIPELINE</p>
      <h2 class="band__title">Students rise. Then they reach back.</h2>
      <p class="band__text" style="max-width:440px">In 2025, Kristia Nahas was named a FIRST Leadership Award Winner (formerly the Dean's List) &mdash; one of just ten students in all of FIRST Robotics Competition worldwide. And she grew here, from curious rookie to technical leader and mentor. She's not the exception; she's the product of a system built to do this for every student. Four alumni currently mentor FIRST teams; one interned at FIRST Headquarters.</p>
      <blockquote class="band-quote">
        <p class="band-quote__text">&ldquo;Robotics to me means a family&hellip; I like that we get to build people up and to help people learn to be what they want to be in the future.&rdquo;</p>
        <footer class="band-quote__attr">KRISTIA NAHAS &middot; MECHANICAL &amp; DESIGN LEAD, CLASS OF 2026 &middot; NOW AT NJIT</footer>
      </blockquote>
      <div class="pipeline pipeline--light">
        <span class="pipeline__step">STUDENT</span>
        <span class="pipeline__sep">&rarr;</span>
        <span class="pipeline__step">GRADUATE</span>
        <span class="pipeline__sep">&rarr;</span>
        <span class="pipeline__step">MENTOR</span>
      </div>
    </div>
    <Image class="split__img split__img--short" src={kristia} widths={[480, 800, 1200, 1600]} sizes="(max-width: 940px) 100vw, 50vw" alt="Kristia Nahas, 2025 FIRST Leadership Award Winner" />
  </section>

</main>

<script src="/js/outcomes.js" defer is:inline></script>

</Base>
