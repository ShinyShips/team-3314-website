---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Marquee from '../components/Marquee.astro';
import sponsors from '../data/sponsors.json';
---
<Base title="Sponsors & Partners — FRC Team 3314" description="Every dollar and mentor hour keeps STEM free for every student in Clifton. Sponsor FRC Team 3314, the Mechanical Mustangs.">

<Nav active="sponsors" />

<main id="main">

  <!-- PAGE HEADER -->
  <section class="page-header">
    <p class="eyebrow eyebrow--dim">SPONSORS &amp; PARTNERS</p>
    <h1 class="page-header__title">Built to last,<br>together</h1>
    <p class="page-header__lede">Every dollar and mentor hour keeps STEM free for every student in Clifton &mdash; and funds outreach that reaches thousands more.</p>
  </section>

  <!-- WHAT FUNDING DOES -->
  <section class="section reveal">
    <div class="section-head">
      <h2 class="section-title">01 &mdash; Where your support goes</h2>
    </div>
    <div class="stat-grid">
      <div class="stat-grid__cell">
        <span class="stat-grid__num" data-count>$0</span>
        <span class="stat-grid__label">DUES &mdash; EVERY STUDENT PARTICIPATES FREE</span>
      </div>
      <div class="stat-grid__cell">
        <span class="stat-grid__num" data-count>3</span>
        <span class="stat-grid__label">FLL TEAMS FULLY FUNDED IN OUR DISTRICT</span>
      </div>
      <div class="stat-grid__cell">
        <span class="stat-grid__num" data-count>$13K+</span>
        <span class="stat-grid__label">IN TAKE-HOME STEM BAGS FOR CLIFTON KIDS</span>
      </div>
      <div class="stat-grid__cell">
        <span class="stat-grid__num" data-count>1000s</span>
        <span class="stat-grid__label">REACHED ANNUALLY THROUGH EVENTS &amp; DEMOS</span>
      </div>
    </div>
    <p style="margin:20px 0 0;font:400 14px/1.6 var(--font-display);color:var(--muted);max-width:640px">Funding covers registration, materials, machining stock, nightly build-season meals, travel, and outreach events &mdash; nothing goes to salaries or overhead. A full season costs roughly $132,000 to run, and 90% of our students qualify for free or reduced-price lunch: sponsorship is what keeps the team free for every one of them.</p>
  </section>

  <!-- PARTNERS -->
  <section class="section section--white reveal">
    <div class="section-head">
      <h2 class="section-title">02 &mdash; Our partners</h2>
      <span class="kicker">FUNDING &middot; MATERIALS &middot; MENTORS &middot; ADVOCACY</span>
    </div>
    <div class="card-grid">
      <div class="panel">
        <span class="panel__kicker">ENGINEERING</span>
        <h3 class="panel__title">Montclair Society of Engineers</h3>
        <p class="panel__text">Our deepest partnership and 501(c)(3) fiscal sponsor &mdash; mentors, operational support, tax-deductible giving, and co-hosting NJ's largest FLL qualifier.</p>
      </div>
      <div class="panel">
        <span class="panel__kicker">CORPORATE</span>
        <h3 class="panel__title">L3Harris &amp; DoDSTEM</h3>
        <p class="panel__text">Funding, materials, and advocacy that keep the program sustainable year over year.</p>
      </div>
      <div class="panel">
        <span class="panel__kicker">COMMUNITY</span>
        <h3 class="panel__title">Mountainside Hospital &amp; Patel Brothers</h3>
        <p class="panel__text">Local partners providing funding, meals, and connections across Clifton and beyond.</p>
      </div>
    </div>
    <Marquee wrapClass="marquee--framed" label="Our sponsors" logos={sponsors} />
  </section>

  <!-- SPONSORSHIP TIERS -->
  <section class="section reveal">
    <div class="section-head">
      <h2 class="section-title">03 &mdash; Sponsorship tiers</h2>
      <a class="mono-link" href="/assets/3314-sponsorship-packet-2025-26.pdf" target="_blank" rel="noopener">DOWNLOAD THE FULL PACKET (PDF) &darr;</a>
    </div>
    <div class="tier-grid">
      <div class="tier tier--top">
        <span class="tier__name">DIAMOND</span>
        <span class="tier__amt">$5,000+</span>
        <ul class="tier__list" role="list">
          <li>Name &amp; logo on all team displays</li>
          <li>Called out during team introductions</li>
          <li>Everything in Platinum</li>
        </ul>
      </div>
      <div class="tier">
        <span class="tier__name">PLATINUM</span>
        <span class="tier__amt">$1,000&ndash;$4,999</span>
        <ul class="tier__list" role="list">
          <li>Name &amp; logo displayed on the robot</li>
          <li>Everything in Gold</li>
        </ul>
      </div>
      <div class="tier">
        <span class="tier__name">GOLD</span>
        <span class="tier__amt">$500&ndash;$999</span>
        <ul class="tier__list" role="list">
          <li>Name &amp; logo on the team uniform</li>
          <li>Official team T-shirt</li>
          <li>Everything in Silver</li>
        </ul>
      </div>
      <div class="tier">
        <span class="tier__name">SILVER</span>
        <span class="tier__amt">$100&ndash;$499</span>
        <ul class="tier__list" role="list">
          <li>Acknowledgement plaque suitable for display</li>
          <li>Everything in Bronze</li>
        </ul>
      </div>
      <div class="tier">
        <span class="tier__name">BRONZE</span>
        <span class="tier__amt">Under $100</span>
        <ul class="tier__list" role="list">
          <li>A personalized thank-you card signed by the team</li>
        </ul>
      </div>
    </div>
    <p style="margin:20px 0 0;font:400 14px/1.6 var(--font-display);color:var(--muted);max-width:640px">In-kind donations &mdash; parts, tools, software, print services, advertising space, meals &mdash; are just as welcome and are recognized at the equivalent tier. Reach us at <a href="mailto:donate@frc3314.com">donate@frc3314.com</a>.</p>
  </section>

  <!-- PRESS -->
  <section class="press">
    <span class="eyebrow eyebrow--muted">AS FEATURED IN</span>
    <div class="press__names">
      <span class="press__name">Clifton Merchant</span>
      <a class="press__name" href="https://www.thecliftontimes.com/articles/featured-stories/the-wins-keep-coming-for-chs-robotics-team-the-mechanical-mustangs/" target="_blank" rel="noopener">Clifton Times</a>
      <span class="press__name">Picatinny Family Day</span>
      <span class="press__name">NJ Manufacturing Day</span>
    </div>
  </section>

  <!-- SPONSOR CTA -->
  <section class="band band--cta reveal">
    <p class="eyebrow eyebrow--band">04 &mdash; BECOME A SPONSOR</p>
    <h2 class="band__title band__title--xl">Invest in a proven pipeline</h2>
    <p class="band__text">92% of our alumni enter STEM fields. Your support turns Clifton students into the engineers your industry needs.</p>
    <div class="band__actions">
      <a class="btn btn--white" href="mailto:admin@frc3314.com">EMAIL admin@frc3314.com</a>
      <a class="btn btn--ghost" href="/assets/3314-sponsorship-packet-2025-26.pdf" target="_blank" rel="noopener">SPONSORSHIP PACKET (PDF)</a>
    </div>
    <p style="margin:0;font:400 13px/1.7 var(--font-mono);color:rgba(255,255,255,.6);max-width:620px">Donations are tax-deductible through our 501(c)(3) fiscal sponsor, the Montclair Society of Engineers (EIN 22-6075853). Checks payable to &ldquo;Montclair Society of Engineers&rdquo; &mdash; 82 Gordonhurst Ave, Montclair, NJ 07043, c/o James Hobin. In-kind donations: <a href="mailto:donate@frc3314.com" style="color:#fff">donate@frc3314.com</a>.</p>
  </section>

</main>

</Base>
