---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
---
<Base title="Message Sent — FRC Team 3314" description="Your message is on its way to FRC Team 3314 — we read everything and reply fast.">

<Nav />

<main id="main">

  <!-- PAGE HEADER -->
  <section class="page-header page-header--tight">
    <p class="eyebrow eyebrow--dim">MESSAGE SENT</p>
    <h1 class="page-header__title">Got it &mdash; talk soon</h1>
    <p class="page-header__lede">Your note is in the team's inbox. We read everything and usually reply within a day or two.</p>
  </section>

  <!-- BACK CTA -->
  <section class="next next--white">
    <div class="next__label">
      <p class="eyebrow eyebrow--muted">MEANWHILE</p>
      <p class="next__title">See what we're building</p>
    </div>
    <a class="btn" href="/">BACK TO THE HOMEPAGE &rarr;</a>
  </section>

</main>

</Base>
