---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

const { title, description } = Astro.props;
const ogImage = new URL('/assets/og-image.jpg', Astro.site);
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
<meta property="og:type" content="website">
<meta property="og:site_name" content="FRC Team 3314 — The Mechanical Mustangs">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:url" content={canonical}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="Team 3314's robot competing on the field during a match">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImage}>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@62..125,100..900&family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
<script is:inline>
// Mirror the page-slide view transition when the user navigates back.
// Must run before first render, hence inline in <head>. Browsers without
// pagereveal/Navigation API skip it and keep the forward slide.
addEventListener('pagereveal', function (e) {
  if (!e.viewTransition || !self.navigation || !navigation.activation) return;
  var a = navigation.activation;
  if (a.navigationType === 'traverse' && a.from && a.entry.index < a.from.index) {
    document.documentElement.setAttribute('data-vt-back', '');
    e.viewTransition.finished.finally(function () {
      document.documentElement.removeAttribute('data-vt-back');
    });
  }
});
</script>
</head>
<body>
<a class="skip-link" href="#main">Skip to content</a>
<slot />
<Footer />
<script src="/js/site-fx.js" defer is:inline></script>
</body>
</html>
