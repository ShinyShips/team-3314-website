---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

const { title, description } = Astro.props;
const ogImage = new URL('/assets/og-image.jpg', Astro.site);
const canonical = new URL(Astro.url.pathname, Astro.site);

// Google Analytics 4 — paste the real Measurement ID here to activate it.
// Until then it stays dormant (no scripts load).
const GA_ID = 'G-N0MNYNKGFT';
const gaEnabled = GA_ID.startsWith('G-') && !GA_ID.includes('XXXX');

// Site-wide structured data — tells search engines what this entity is and
// where it operates (helps New Jersey / North Jersey regional relevance).
const orgLd = {
  '@context': 'https://schema.org',
  // Multiple types: we compete (SportsTeam) AND educate/mentor
  // (EducationalOrganization). A schema.org entity can be several things.
  '@type': ['SportsTeam', 'EducationalOrganization'],
  name: 'FRC Team 3314',
  alternateName: 'The Mechanical Mustangs',
  description:
    'Student-run FIRST Robotics Competition team and STEM education program in Clifton, New Jersey — competing while mentoring younger FLL and FRC teams and running free community outreach across North Jersey.',
  sport: 'FIRST Robotics Competition',
  knowsAbout: ['FIRST Robotics', 'STEM education', 'robotics', 'engineering', 'community outreach'],
  url: Astro.site.href,
  logo: new URL('/assets/logo-white.png', Astro.site).href,
  foundingDate: '2010',
  email: 'admin@frc3314.com',
  location: {
    '@type': 'Place',
    name: 'Clifton High School',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '333 Colfax Avenue',
      addressLocality: 'Clifton',
      addressRegion: 'NJ',
      postalCode: '07013',
      addressCountry: 'US',
    },
  },
  areaServed: [
    { '@type': 'State', name: 'New Jersey' },
    { '@type': 'Place', name: 'North Jersey' },
  ],
  memberOf: {
    '@type': 'Organization',
    name: 'FIRST (For Inspiration and Recognition of Science and Technology)',
    url: 'https://www.firstinspires.org/',
  },
  sameAs: [
    'https://www.instagram.com/team3314',
    'https://www.thebluealliance.com/team/3314',
  ],
};
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
{gaEnabled && (
  <Fragment>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA_ID}');`}></script>
  </Fragment>
)}
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
<link rel="icon" href="/assets/favicon.ico" sizes="any">
<link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png">
<link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
<link rel="manifest" href="/assets/site.webmanifest">
<meta name="theme-color" content="#6D0F0F">
<meta property="og:type" content="website">
<meta property="og:site_name" content="FRC Team 3314 — The Mechanical Mustangs">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:url" content={canonical}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="Team 3314's robot competing on the field during a match">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImage}>
<script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@62..125,100..900&family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&family=Newsreader:ital,opsz,wght@1,6..72,400..600&display=swap" rel="stylesheet">
<script is:inline>
// Mirror the page-slide view transition when the user navigates back.
// Must run before first render, hence inline in <head>. Browsers without
// pagereveal/Navigation API skip it and keep the forward slide.
addEventListener('pagereveal', function (e) {
  if (!e.viewTransition || !self.navigation || !navigation.activation) return;
  var a = navigation.activation;
  if (a.navigationType === 'traverse' && a.from && a.entry.index < a.from.index) {
    document.documentElement.setAttribute('data-vt-back', '');
    e.viewTransition.finished.finally(function () {
      document.documentElement.removeAttribute('data-vt-back');
    });
  }
});
</script>
</head>
<body>
<a class="skip-link" href="#main">Skip to content</a>
<slot />
<Footer />
<script src="/js/site-fx.js" defer is:inline></script>
</body>
</html>
